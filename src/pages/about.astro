---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import AboutSection from "../components/About.astro";
import Statement from "../components/Statement.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { profile } from "../data/profile";
---

<BaseLayout
  title="About"
  description={profile.longBio}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: "About XHVERSE",
    url: "https://xhverse.co/about",
    mainEntity: {
      "@type": "Person",
      name: profile.name,
      description: profile.longBio,
      image: `https://xhverse.co${profile.avatar}`,
      email: profile.email,
    },
  }}
>
  <Header current="/about" />
  <main>
    <AboutSection />
    <Statement />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
