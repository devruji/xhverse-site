---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { items } from "../data/gallery";
---

<BaseLayout
  title="Gallery"
  description="Visual fragments, references, and collected frames from the XHVERSE archive."
  structuredData={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "XHVERSE Gallery",
    url: "https://xhverse.co/gallery",
    description:
      "Visual fragments, references, and collected frames from the XHVERSE archive.",
  }}
>
  <Header current="/gallery" />
  <main class="section">
    <div class="container">
      <h1>Gallery</h1>
      <div class="grid grid--gallery">
        {items.map((item) => (
          <figure class="gallery-item">
            <img
              src={item.src}
              alt={item.alt}
              width={item.width}
              height={item.height}
              loading="lazy"
              decoding="async"
            />
            <figcaption>{item.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
